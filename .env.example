# Supabase Postgres connection string.
# Local dev / drizzle-kit migrations: Session pooler (port 5432).
# Production runtime on Vercel: Transaction pooler (port 6543) with
# `?pgbouncer=true&connect_timeout=10` and the postgres-js driver
# configured with `prepare: false` (already set in src/db/index.ts).
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Mapbox public token. `pk.eyJ...` from https://account.mapbox.com/access-tokens/.
# Safe to expose to the browser; restrict to your domains in the Mapbox dashboard.
NEXT_PUBLIC_MAPBOX_TOKEN="pk.eyJ1Ijoi..."

# Anthropic API key. `sk-ant-...` from https://console.anthropic.com/settings/keys.
# Server-only — DO NOT prefix with NEXT_PUBLIC_. Used by the AI editor at
# /submit; without it, submissions still persist but the AI pre-screen
# falls through to human review with an explanatory note.
ANTHROPIC_API_KEY="sk-ant-..."

# OpenAI API key. `sk-...` from https://platform.openai.com/api-keys.
# Server-only — DO NOT prefix with NEXT_PUBLIC_. Used by the voice-to-fiction
# pipeline at /api/transcribe (Whisper, $0.006/min). Without it the voice
# capture demo will return 503.
OPENAI_API_KEY="sk-..."

# ── Supabase Auth ───────────────────────────────────────────────────────────
# Project URL and ANON public key — both browser-safe. Get them from
# Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Service role key — SERVER ONLY. DO NOT prefix with NEXT_PUBLIC_. This
# bypasses RLS and has full admin privileges; leaking it = full DB
# compromise. Used only by /api/auth/invite to call
# `supabase.auth.admin.inviteUserByEmail` for closed-signup invites.
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Bearer token gating /api/diagnose + /api/dev/* + the /dev/eval browser UI.
# Generate one fresh secret per environment (e.g. `openssl rand -hex 32`).
# Without it, the routes return 503 — fail-closed rather than serving Claude
# calls to anyone who finds the URL. Internal consumers (story-gate-eval
# Python harness, browser UI) authenticate either by `Authorization: Bearer
# <this value>` header or by a same-name httpOnly cookie set by the UI form.
DIAGNOSTIC_INTERNAL_TOKEN="generate-with-openssl-rand-hex-32"
