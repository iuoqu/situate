# Supabase Postgres connection string.
# Local dev / drizzle-kit migrations: Session pooler (port 5432).
# Production runtime on Vercel: Transaction pooler (port 6543) with
# `?pgbouncer=true&connect_timeout=10` and the postgres-js driver
# configured with `prepare: false` (already set in src/db/index.ts).
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Mapbox public token. `pk.eyJ...` from https://account.mapbox.com/access-tokens/.
# Safe to expose to the browser; restrict to your domains in the Mapbox dashboard.
NEXT_PUBLIC_MAPBOX_TOKEN="pk.eyJ1Ijoi..."

# Anthropic API key. `sk-ant-...` from https://console.anthropic.com/settings/keys.
# Server-only — DO NOT prefix with NEXT_PUBLIC_. Used by the AI editor at
# /submit; without it, submissions still persist but the AI pre-screen
# falls through to human review with an explanatory note.
ANTHROPIC_API_KEY="sk-ant-..."
